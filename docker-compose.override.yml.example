# docker-compose.override.yml — LOCAL ONLY, não commitar
# Copie este arquivo como docker-compose.override.yml e ajuste conforme necessário.

services:
  escolinhapro_app_fpm:
    # Descomente para habilitar Xdebug
    # environment:
    #   XDEBUG_MODE: develop,debug
    #   XDEBUG_CONFIG: client_host=host.docker.internal
    pass: null

  escolinhapro_app_postgres:
    # Porta alternativa para evitar conflito com Postgres instalado localmente
    ports:
      - "54320:5432"

  escolinhapro_app_redis:
    # Porta alternativa para evitar conflito com Redis instalado localmente
    ports:
      - "63790:6379"
